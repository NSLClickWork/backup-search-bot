# Discord Configurations
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_discord_guild_id_for_testing

# AI LLM Configurations (Groq or OpenAI)
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key_optional

# Google Workspace API Credentials
# (Can use Service Account JSON file path or Client Credentials with Refresh Token)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email_optional
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=your_service_account_private_key_optional
GOOGLE_REFRESH_TOKEN=your_oauth_refresh_token_optional
GOOGLE_CLIENT_ID=your_google_client_id_optional
GOOGLE_CLIENT_SECRET=your_google_client_secret_optional

# Microsoft 365 / Entra ID Configurations
MS_TENANT_ID=your_microsoft_tenant_id
MS_CLIENT_ID=your_microsoft_client_id
MS_CLIENT_SECRET=your_microsoft_client_secret
MS_SHAREPOINT_SITE_ID=your_sharepoint_site_id_optional

# Backup Configurations
BACKUP_SOURCE_DIR=c:/Users/SonTrung/Downloads/plan
BACKUP_DEST_DIR=c:/Users/SonTrung/Downloads/plan/backups
BACKUP_CRON_SCHEDULE="0 2 * * *" # Every day at 2:00 AM
